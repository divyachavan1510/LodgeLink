<% layout("layout/boilerplate") -%>
     <div class="row mt-3">
        <div class="col-8 offset-2">

           <form method="post" action="/listing/<%= list._id %>?_method=put" novalidate class="needs-validation" enctype="multipart/form-data">

        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" value="<%= list.title %>" type="text" class="form-control" required>   
             <div class="valid-feedback">Title looks good!</div>
        </div>

      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" value="<%= list.description %>" class="form-control" required><%= list.description %></textarea>
         <div class="invalid-feedback">Please enter a short description</div>
      </div>
      
      <div class="mb-3">
        Original Image<br>
            <img src="<%=originalimg%>">
          </div>
    
       <div class="mb-3">

          <label for="image" class="form-label">Image</label>
        <input name="listing[image]" value="<%=originalimg%>" type="file" class="form-control">
         <div class="invalid-feedback">Upload New Image</div>
        </div>
 

        <div class="mb-3">
        <label for="location" class="form-label">Location</label>
       <input name="listing[location]" value="<%= list.location %>" type="text" class="form-control" required>
        <div class="invalid-feedback">Please enter valid location</div>
       

        
        </div>

        <div class="mb-3">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" value="<%= list.price %>" type="number" class="form-control" required>
            <div class="invalid-feedback">Please enter valid price</div>
        </div>

        <div class="mb-3">
              <label for="country" class="form-label">Country</label>
       <input name="listing[country]" value="<%= list.country %>" type="text" class="form-control" required>
         <div class="invalid-feedback">Please enter valid country</div>
        </div>
      
       <br>
        <button type="submit" class="btn btn-dark edit-btn mt-3">Edit</button>
    
    </form>
    <br>


</div>

 