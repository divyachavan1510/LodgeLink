<% layout("layout/boilerplate") -%>
<%= success %>
<body>
    <!-- <h1>All Listings</h1> -->

    <style>
        #filters{
             display:flex;
             flex-wrap: wrap;        
        }
        .filter{
             text-align-center;
            margin-left:2rem;
             margin-right:2rem;
            opacity: 0.7;
            
          
        }
        .filter:hover{
             opacity: 1;
               cursor:pointer;
        }
        .filter p{
           font-size: 0.8rem;
}
    </style>

   <div id="filters">
    <div class="filter">
        <i class="fa-solid fa-fire"></i>
        <p>Trending</p>
    </div>
    <div class="filter">
        <i class="fa-solid fa-bed"></i>
        <p>Room</p>
    </div>
    <div class="filter">
       <i class="fa-solid fa-mountain-city"></i>
        <p>Iconic Cities</p>
    </div>
    <div class="filter">
       <i class="fa-solid fa-synagogue"></i>
        <p>Castles</p>
    </div>
    <div class="filter">
       <i class="fa-solid fa-person-swimming"></i>
        <p>Amazing Pools</p>
    </div>
      
<div class="filter">
       <i class="fa-solid fa-umbrella-beach"></i>
        <p>Beach Umbrella</p>
</div>

        <div class="filter">
       <i class="fa-solid fa-snowflake"></i>
        <p>Snowflake</p>

    </div>
   </div>



    <div class="container">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-1">
            <% for(let list of listings) { %>
                <a href="/show/<%=list._id %>" class="listing-link">
                    <div class="col" >
                    <div class="card h-100" style="border: none;">
                    <!-- <img src="<%= list.image.url %>" class="card-img-top" style="height: 20rem;" alt="..."> -->
                    <% if (list.image && list.image.url) { %>
  <img src="<%= list.image.url %>" class="card-img-top" style="height: 20rem;" alt="...">
<% } else { %>
  <img src="https://via.placeholder.com/300x200?text=No+Image" class="card-img-top" style="height: 20rem;" alt="No Image Available">
<% } %>

                     <div class="card-img-overlay">
                        <!-- <h2>card</h2> -->
  </div>
                    <div class="card-body">
                        <h5 class="card-title"><%= list.title %></h5>
                        <p class="card-text">₹<%= list.price %>/night</p>


                    </div>
                    </div>
                    </div>
                </a>
            
            <% } %>
        </div>
    </div>

</body>
