<% layout("layout/boilerplate") -%>

    <div class="row">
        <div class="col-8 offset-2">

            <h3>Create a New Listing</h3>
            <br>
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
             <label for="title" class="form-label">Title</label>
            <input name="listing[title]" 
             placeholder="Enter title"               
             type="text" 
             class="form-control"
             required >
        <div class="valid-feedback">Title looks good!</div>
        </div>
       
    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
       <textarea 
       name="listing[description]" 
       placeholder="Enter Description" 
       class="form-control"
      required></textarea>
      <div class="invalid-feedback">Please enter a short description</div>
    </div>
       

        <div class="mb-3">
        <label for="image" class="form-label">Upload Image</label>
        <input name="listing[image]" placeholder="Enter url/link of image" type="file" class="form-control" required>
       </div>
      
       <div class="row">

        <div class="mb-3 col-4">
        <label for="price" class="form-label">Price</label>
       <input name="listing[price]" placeholder="1500" class="form-control" required>
        <div class="invalid-feedback">Please enter valid price</div>

        

       </div>
       
       
      <div class="mb-3 col-8">
        <label for="country" class="form-label">Country</label>
        <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
         <div class="invalid-feedback">Please enter valid country</div>
      </div>

       </div>
       
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input name="listing[location]" placeholder="Goa" type="text" class="form-control" required>
         <div class="invalid-feedback">Please enter valid location</div>
      </div>
      
       
      
        <button type="submit" class="btn btn-dark add-btn">Add</button>
        
    </form>
        <br>
        </div>
        

        



    </div>
    